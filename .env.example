# ============================================
# AI Agency in a Box v3 — Environment Config
# ============================================
# Copy this file to .env and fill in your values

# --- Encryption ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# --- LLM Providers (add the ones you use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Ollama (local LLM — optional, free) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Search (optional) ---
TAVILY_API_KEY=

# --- LiteLLM Sidecar ---
LITELLM_MASTER_KEY=sk-litellm-master-key
LITELLM_PORT=4000

# --- App ---
APP_PORT=3000
APP_URL=http://localhost:3000
NODE_ENV=development

# --- Database ---
DATABASE_URL=file:./data/agency.db
